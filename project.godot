; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[Fmod]

General/banks_path="res://fmod_banks/Desktop"

[application]

config/name="ohye"
config/description="You find your"
run/main_scene="uid://b4lpa2lw8g4ku"
config/use_custom_user_dir=true
config/custom_user_dir_name="ohye"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/max_fps=260
boot_splash/bg_color=Color(0, 0, 0, 0)
boot_splash/show_image=false
config/icon="res://entities/eye/eye.png"

[audio]

buses/default_bus_layout="uid://cr6eqw6ih0ldv"
general/3d_panning_strength=1.0

[autoload]

Shaker="*uid://cg3c5ha17b2gf"
Global="*res://utils/global.tscn"
FmodManager="*uid://cds10pm7hwn3p"
GlobalFmodBankLoader="*res://global/fmod_bank_loader.tscn"
Transition="*res://global/transition.tscn"
AchievementManager="*res://global/achievement_manager.tscn"
GlobalObserver="*res://utils/global_observer.gd"
InputCounter="*res://utils/input_counter.tscn"
Music="*uid://bti6khuuptmnx"
LevelHandler="*uid://dpl3ppt62bdix"
Map="*uid://uvxalm5atevp"

[display]

window/size/borderless=true
window/size/transparent=true
window/vsync/vsync_mode=0

[editor_plugins]

enabled=PackedStringArray("res://addons/fmod/plugin.cfg", "res://addons/func_godot/plugin.cfg", "res://addons/raytraced_audio/plugin.cfg", "res://addons/richtext2/plugin.cfg", "res://addons/shaker/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "purple",
"res://components/": "orange",
"res://compositor_effects/": "gray",
"res://entities/": "orange",
"res://entities/player/": "orange",
"res://entities/player/sounds/": "blue",
"res://music/": "blue",
"res://shaders/": "gray",
"res://shakes/": "gray",
"res://utils/": "teal",
"res://world/": "orange"
}

[func_godot]

model_point_class_save_path="tb/point_class"

[global_group]

enemy=""
visibility_parent=""

[gui]

theme/custom_font="uid://bwfwowg4owg61"

[importer_defaults]

texture={
"compress/channel_pack": 0,
"compress/hdr_compression": 1,
"compress/high_quality": false,
"compress/lossy_quality": 0.7,
"compress/mode": 0,
"compress/normal_map": 0,
"detect_3d/compress_to": 0,
"mipmaps/generate": true,
"mipmaps/limit": -1,
"process/fix_alpha_border": true,
"process/hdr_as_srgb": false,
"process/hdr_clamp_exposure": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"process/size_limit": 0,
"roughness/mode": 0,
"roughness/src_normal": ""
}

